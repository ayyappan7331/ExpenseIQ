# Copy this file to `.env` and fill in real values. Never commit `.env`.

# HTTP port the API listens on
PORT=5000

# MongoDB connection string.
# Local example:  mongodb://127.0.0.1:27017/expenseiq
# Atlas example:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?appName=ExpenseIQ
MONGO_URI=mongodb://127.0.0.1:27017/expenseiq

# development | production | test
NODE_ENV=development

# Input-validation mode for POST/PUT/bulk routes.
#   shadow  = run schemas, log mismatches, but ALWAYS forward to controller (default)
#   enforce = run schemas, reject mismatched payloads with 400 BEFORE the controller
# Leave empty / unset to use shadow.
VALIDATION_MODE=shadow

# CORS allowlist (Phase 4). Comma-separated list of allowed Origin values.
# Leave empty / unset to default-allow any http(s)://localhost:* and 127.0.0.1:*.
# Examples:
#   CORS_ORIGIN=http://localhost:5500
#   CORS_ORIGIN=http://localhost:5500,http://localhost:3000
CORS_ORIGIN=

# Rate limit (Phase 4). Applies to all /api/* routes.
# Defaults are 300 requests per 60s per IP (very generous for localhost dev).
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Authentication (Phase 7). Disabled by default — existing frontend keeps
# working unchanged. Set to "true" only when you have a frontend that
# obtains and sends an Authorization: Bearer <token> header.
AUTH_ENABLED=false

# JWT secret. REQUIRED when AUTH_ENABLED=true. Long random string.
# Example: openssl rand -hex 32
JWT_SECRET=

# JWT expiry. Accepts ms-format strings (e.g. "7d", "12h", "30m") or seconds.
JWT_EXPIRY=7d

# Logging (Phase 8). pino level: trace | debug | info | warn | error | fatal | silent.
# Defaults to "info" in dev, "silent" in tests.
LOG_LEVEL=

# Optional. If set, /api/version returns this string as gitSha. Otherwise the
# server tries `git rev-parse HEAD` at boot and falls back to "unknown".
GIT_SHA=
