{
  "name": "expenseiq-backend",
  "version": "1.0.0",
  "description": "ExpenseIQ Backend API - Intelligent Spend Tracker",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --ext js,ts,json --exec \"node -r ts-node/register server.js\"",
    "dev:qa": "cross-env NODE_ENV=qa nodemon --ext js,ts,json --exec \"node -r ts-node/register server.js\"",
    "start": "node -r ts-node/register server.js",
    "start:qa": "cross-env NODE_ENV=qa node -r ts-node/register server.js",
    "seed": "node utils/seed.js",
    "migrate:dates": "node -r ts-node/register utils/migrate-dates.js",
    "migrate:dates:apply": "node -r ts-node/register utils/migrate-dates.js --apply",
    "migrate:dates:reverse": "node -r ts-node/register utils/migrate-dates.js --apply --reverse",
    "migrate:repair": "node -r ts-node/register scripts/repairOrphanedDocuments.js",
    "migrate:repair:apply": "node -r ts-node/register scripts/repairOrphanedDocuments.js --apply",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md}\""
  },
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.0",
    "pino": "^9.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.2",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.5"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
